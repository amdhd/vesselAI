# --- Python ---
.venv/
.venv-dashboard/
__pycache__/
*.pyc

# --- DuckDB warehouse (regenerated by the pipeline; never commit) ---
data/*.duckdb
data/*.duckdb.wal

# --- Raw data ---
# Ignore large downloaded NOAA files, but keep the tiny synthetic sample so the
# repo runs out of the box for anyone who clones it.
data/raw/*.csv
!data/raw/ais_sample.csv
data/raw/*.zip
data/*.csv          # large synthetic files from the scale demo (e.g. ais_large.csv)

# --- dbt (created in Phase 2) ---
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml

# --- macOS ---
.DS_Store
