# =============================================================================
# VesselMind AI — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://vesselmind:vesselmind_secret@localhost:5432/vesselmind
POSTGRES_USER=vesselmind
POSTGRES_PASSWORD=vesselmind_secret
POSTGRES_DB=vesselmind

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=replace_with_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Anthropic Claude API (REQUIRED for AI features)
# Get your key at: https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Frontend (Vite)
# These are prefixed with VITE_ so they are exposed to the browser
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3001/api
VITE_SOCKET_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Optional: External APIs (mock data used if not provided)
# -----------------------------------------------------------------------------
# StormGlass API for real weather data
STORMGLASS_API_KEY=

# MarineTraffic API for real AIS vessel tracking
MARINETRAFFIC_API_KEY=

# OpenWeatherMap fallback
OPENWEATHERMAP_API_KEY=

# -----------------------------------------------------------------------------
# Demo Mode (pre-seeded in DB — no config needed)
# Demo credentials:
#   Email: demo@petronas.com
#   Password: demo123
# -----------------------------------------------------------------------------
