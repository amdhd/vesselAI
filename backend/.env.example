DATABASE_URL="postgresql://username:password@localhost:5432/vesselmind"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
ANTHROPIC_API_KEY="your-anthropic-api-key"
PORT=3001
FRONTEND_URL="http://localhost:5173"

# Operational config (validated at boot by src/config/env.ts).
# NODE_ENV=production makes JWT_SECRET + DATABASE_URL mandatory (fail-fast).
NODE_ENV="development"
# fatal|error|warn|info|debug|trace|silent. Defaults: info in prod, debug in dev, silent in test.
LOG_LEVEL=""
# Number of proxy hops (e.g. 1 behind a load balancer) so req.ip is the real client.
TRUST_PROXY=""
# If set, GET /metrics requires  Authorization: Bearer <token>.
METRICS_TOKEN=""

# Open-Meteo Marine ingestion pipeline (free, no API key required).
# Enable the scheduled ingestion once DATABASE_URL points at a live Postgres.
ENABLE_WEATHER_SYNC="false"
WEATHER_SYNC_INTERVAL_MS="900000"

# aisstream.io live AIS vessel positions (WebSocket, free non-commercial key).
# Put your real key in backend/.env (gitignored) — never commit it here.
AISSTREAM_API_KEY=""
ENABLE_AIS_STREAM="false"
