DATABASE_URL="postgresql://username:password@localhost:5432/vesselmind"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
ANTHROPIC_API_KEY="your-anthropic-api-key"
PORT=3001
FRONTEND_URL="http://localhost:5173"

# Open-Meteo Marine ingestion pipeline (free, no API key required).
# Enable the scheduled ingestion once DATABASE_URL points at a live Postgres.
ENABLE_WEATHER_SYNC="false"
WEATHER_SYNC_INTERVAL_MS="900000"

# aisstream.io live AIS vessel positions (WebSocket, free non-commercial key).
# Put your real key in backend/.env (gitignored) — never commit it here.
AISSTREAM_API_KEY=""
ENABLE_AIS_STREAM="false"
