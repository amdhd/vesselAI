{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "backend", "run", "dev"],
      "port": 3001
    },
    {
      "name": "analytics-api",
      "runtimeExecutable": "data-platform/.venv/bin/uvicorn",
      "runtimeArgs": ["api.main:app", "--port", "8000", "--app-dir", "data-platform"],
      "port": 8000
    }
  ]
}
